# LLM provider keys (fill the ones you intend to use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Postgres (asyncpg). docker-compose overrides this for the backend service.
DATABASE_URL=postgresql+asyncpg://felo:felo@localhost/felo_coach

# Redis (reserved for rate-limit / session TTL upgrades)
REDIS_URL=redis://localhost:6379

# Defaults used when client doesn't specify
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6

# Session memory (in-process; never persisted)
SESSION_TTL_MINUTES=30
MAX_SESSION_MESSAGES=20

LOG_LEVEL=INFO
ENVIRONMENT=development
